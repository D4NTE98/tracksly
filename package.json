{
  "name": "tracksly",
  "version": "0.1.0",
  "private": true,
  "description": "Modern DJ set builder built with Electron, React and TypeScript.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && tsc -p tsconfig.electron.json && electron .\"",
    "build": "tsc --noEmit && tsc -p tsconfig.electron.json && vite build && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@electron/remote": "^2.1.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "electron-store": "^10.0.1",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "music-tempo": "^1.0.3",
    "uuid": "^11.0.0",
    "wavesurfer.js": "^7.9.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1",
    "@types/node": "^22.10.1"
  },
  "build": {
    "appId": "com.tracksly.app",
    "productName": "Tracksly",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
